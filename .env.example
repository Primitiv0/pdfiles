# Path to your documents folder (required)
DATA_PATH=/path/to/your/documents

# Web UI port (default: 80)
WEB_PORT=80

# Set to true to enable indexing and export features
# Disable this if you are sharing with untrusted users
ADMIN_MODE=true

# GPU device (default: cuda:0). Force CPU: use docker-compose.cpu.yml
# BACKEND_DEVICE=cuda:0
# INDEX_DEVICE=cuda:0
